# Apache .htaccess for PHP Front Controller Routing
RewriteEngine On

# HTTPS 강제 적용
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# www를 non-www로 리디렉션 (선택사항)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# 실제 파일이나 디렉토리가 존재하지 않으면 index.php로 전달
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?route=$1 [L,QSA]

# 보안: .env, .git 등 민감 파일 직접 접근 차단
<FilesMatch "^\.(env|git|htaccess|htpasswd|ini|phar|lock|json|md|bak|sql|sh|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 보안 헤더 설정
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval'"
</IfModule>

# PHP 설정
php_value upload_max_filesize 10M
php_value post_max_size 10M
php_value max_execution_time 300
php_value max_input_time 300 